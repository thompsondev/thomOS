# Database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/thomos"
# Auto-create/update tables from entities (default: on in non-production, off in production)
# TYPEORM_SYNC="true"

# Claude (required)
ANTHROPIC_API_KEY="your-anthropic-api-key"
# Claude model id (optional; default: claude-sonnet-4-5-20250929)
AI_MODEL="claude-sonnet-4-5-20250929"

# Auth (JWT)
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
# Optional override for `pnpm seed` login password (default in code: ChangeMe123!)
# SEED_USER_PASSWORD="ChangeMe123!"

# Server
PORT=3000
# Optional; if set, all routes require x-api-key header matching this value
# API_KEY="your-secret-api-key"

# When API_KEY is not set: only requests whose Host matches a domain listed in DOMAIN_CHAT are limited per day per IP; all other domains are unlimited. DOMAIN_CHAT can be one or more hostnames, comma-separated (e.g. chat.example.com or chat.a.com,chat.b.com). Limit per listed domain: default 5, or PROMPTS_PER_DAY_CHAT. Omit DOMAIN_CHAT for unlimited prompts everywhere.
# DOMAIN_CHAT="chat.example.com"
# DOMAIN_CHAT="chat.a.com,chat.b.com"
# PROMPTS_PER_DAY_CHAT=5

# Swagger / docs (optional). PLATFORM_URL also controls branding: copyright is shown only when request host matches this URL's host or is a subdomain.
PLATFORM_NAME="thomOS.ai"
PLATFORM_URL="http://localhost:3000"
DEVELOPMENT_URL="localhost:3000"
PRODUCTION_URL="your-production-host.com"

# CORS — origins allowed in addition to all localhost ports (http/https)
# Comma-separated list of fully-qualified origins (no trailing slash)
# CORS_ORIGINS="https://your-app.com,https://another-domain.com"

# Branding shown in the demo UI header ("by X") and footer; always shown on localhost, and on PLATFORM_URL or its subdomains; otherwise hidden (optional)
# AUTHOR_NAME="your-name"
# AUTHOR_URL="https://your-website.com"
